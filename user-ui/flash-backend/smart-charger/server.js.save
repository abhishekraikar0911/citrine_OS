require("dotenv").config();
const express = require("express");
const stripe = require("stripe")(process.env.STRIPE_SECRET_KEY);
const bodyParser = require("body-parser");
const axios = require("axios");
const { Pool } = require("pg");

const app = express();
app.use(express.json());

// PostgreSQL
const pool = new Pool({
  user: process.env.DB_USER,
  host: process.env.DB_HOST,
  database: process.env.DB_NAME,
  password: process.env.DB_PASS,
  port: process.env.DB_PORT,
});

/* ==========================================
   CREATE CHECKOUT SESSION
========================================== */
app.post("/api/checkouts", async (req, res) => {
  try {
    const { evse_id, target_kwh, success_url, cancel_url } = req.body;

    const session = await stripe.checkout.sessions.create({
      payment_method_types: ["card"],
      mode: "payment",
      line_items: [
        {
          price_data: {
            currency: "inr",
            product_data: { name: "EV Charging" },
            unit_amount: target_kwh * 100 * 10 // example ₹10 per kWh
          },
          quantity: 1,
        },
      ],
      succis_activeess_url,
      cancel_url,
      metadata: {
        evse_id,
        target_kwh
      }
    });

    res.json({ url: session.url });

  } catch (err) {
    console.error(err.message);
    res.status(500).json({ error: err.message });
  }
});

/* ==========================================
   STRIPE WEBHOOK
========================================== */
app.post(
  "/webhook",
  bodyParser.raw({ type: "application/json" }),
  async (req, res) => {

    const sig = req.headers["stripe-signature"];
    let event;

    try {
      event = stripe.webhooks.constructEvent(
        req.body,
        sig,
        process.env.STRIPE_WEBHOOK_SECRET
      );
    } catch (err) {
      console.log("Webhook Error:", err.message);
      return res.sendStatus(400);
    }

    if (event.type === "checkout.session.completed") {

      const session = event.data.object;

      const chargerId = session.metadata.evse_id;
      const targetKwh = parseFloat(session.metadata.target_kwh);

      console.log("Payment success. Starting charger...");

      await startSmartCharging(chargerId, 1, targetKwh);
    }

    res.sendStatus(200);
  }
);

/* ==========================================
   START CHARGING
========================================== */
async function startSmartCharging(chargerId, connectorId, targetKwh) {

  // 1️⃣ Remote Start
  await axios.post(
    `http://localhost:8081/ocpp/1.6/evdriver/remoteStartTransaction?identifier=${chargerId}&tenantId=1`,
    {
      connectorId,
      idTag: "FLASH_USER"
    }
  );

  console.log("RemoteStart sent");

  // 2️⃣ Wait for transaction
  await new Promise(resolve => setTimeout(resolve, 4000));

  const tx = await pool.query(
    `SELECT "transactionId","meterStart"
     FROM "Transactions"
     WHERE "stationId"=$1 AND "isActive"=true
     ORDER BY "transactionId" DESC
     LIMIT 1`,
    [chargerId]
  );

  if (tx.rows.length === 0) {
    console.log("Transaction not found");
    return;
  }

  const transactionId = tx.rows[0].transactionId;
  const startWh = tx.rows[0].meterStart;

  // 3️⃣ Save session
await pool.query(
  `INSERT INTO app_charging_sessions
   (charger_id, connector_id, transaction_id, start_energy, target_kwh, status)
   VALUES ($1,$2,$3,$4,$5,'charging')`,
  [chargerId, connectorId, transactionId, startWh, targetKwh]
);
  console.log("Charging session stored");
}

/* ==========================================
   AUTO MONITOR EVERY 5 SECONDS
========================================== */
setInterval(async () => {

  const sessions = await pool.query(
    `SELECT * FROM app_charging_sessions WHERE status='charging`
  );

  for (const session of sessions.rows) {

    const energy = await pool.query(
      `
      SELECT
        (jsonb_array_elements("sampledValue")->>'value')::numeric AS energy_wh
      FROM "MeterValues"
      WHERE "transactionId"=$1
        AND jsonb_array_elements("sampledValue")->>'measurand'='Energy.Active.Import.Register'
      ORDER BY "createdAt" DESC
      LIMIT 1
      `,
      [session.transaction_id]
    );

    if (energy.rows.length === 0) continue;

    const currentWh = energy.rows[0].energy_wh;
    const consumedKwh = (currentWh - session.start_energy) / 1000;

    console.log("Consumed:", consumedKwh);

    if (consumedKwh >= session.target_kwh) {

      console.log("Target reached. Stopping charger...");

      await axios.post(
        `http://localhost:8081/ocpp/1.6/evdriver/remoteStopTransaction?identifier=${session.station_id}&tenantId=1`,
        {
          transactionId: session.transaction_id
        }
      );

      await pool.query(
        `UPDATE app_charging_sessions
SET status='completed'
WHERE id=$1`,
        [session.id]
      );

      console.log("Stopped automatically ✅");
    }
  }

}, 5000);

/* ==========================================
   SERVER
========================================== */
app.listen(4000, "0.0.0.0", () => {
  console.log("Stripe + Smart Charging running on 4000");
});

# PostgreSQL Configuration
POSTGRES_DB=citrine
POSTGRES_USER=citrine
POSTGRES_PASSWORD=change_me_in_production

# RabbitMQ Configuration
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest_change_in_production

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_in_production

# Hasura Configuration
HASURA_GRAPHQL_ADMIN_SECRET=CitrineOS_change_in_production

# AWS Configuration (for MinIO mock)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Application Configuration
APP_NAME=all
APP_ENV=docker
DB_STRATEGY=sync
BOOTSTRAP_CITRINEOS_CONFIG_FILENAME=config.json
BOOTSTRAP_CITRINEOS_FILE_ACCESS_TYPE=local
BOOTSTRAP_CITRINEOS_FILE_ACCESS_LOCAL_DEFAULT_FILE_PATH=/data
